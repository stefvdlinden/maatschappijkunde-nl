---
import BaseLayout from '../layouts/BaseLayout.astro';
import pages from '../../data/site/pages.json';

export function getStaticPaths() {
  return pages.map((page) => ({
    params: { slug: page.slugParam ?? undefined },
    props: { page }
  }));
}

const { page } = Astro.props;
const title = page.seoTitle || page.title || 'Maatschappijkunde.nl';
const description = page.description || undefined;
---
<BaseLayout title={title} description={description}>
  <article class="legacy-content">
    <p class="meta">{page.typeLabel}</p>
    <h1>{page.title}</h1>
    <div set:html={page.html} />
  </article>
</BaseLayout>
