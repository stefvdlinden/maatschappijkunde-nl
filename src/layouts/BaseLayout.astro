---
const {
  title = 'Maatschappijkunde.nl',
  description = 'Alle examenstof van het VMBO examenvak maatschappijleer 2.'
} = Astro.props;
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">Maatschappijkunde.nl</a>
      <nav aria-label="Hoofdmenu">
        <a href="/examenstof/">Examenstof</a>
        <a href="/kerndoelen/">Kerndoelen</a>
        <a href="/begrippen/">Begrippen</a>
        <a href="/over/">Over</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --text: #202124;
    --muted: #5f6368;
    --line: #d8dde3;
    --accent: #0f766e;
    --bg-soft: #f6f8fa;
  }

  body {
    margin: 0;
    color: var(--text);
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    line-height: 1.6;
    background: #fff;
  }

  a {
    color: var(--accent);
  }

  .site-header {
    display: flex;
    gap: 24px;
    align-items: center;
    justify-content: space-between;
    padding: 16px max(20px, calc((100vw - 1040px) / 2));
    border-bottom: 1px solid var(--line);
  }

  .brand {
    color: var(--text);
    font-weight: 700;
    text-decoration: none;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  nav a {
    color: var(--text);
    text-decoration: none;
  }

  main {
    max-width: 920px;
    margin: 0 auto;
    padding: 32px 20px 56px;
  }

  h1,
  h2,
  h3 {
    line-height: 1.2;
  }

  img,
  iframe {
    max-width: 100%;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
  }

  th,
  td {
    padding: 10px 12px;
    border: 1px solid var(--line);
    vertical-align: top;
  }

  th {
    background: var(--bg-soft);
    text-align: left;
  }

  .meta,
  .notice {
    color: var(--muted);
  }

  .notice {
    padding: 12px 14px;
    border: 1px solid var(--line);
    background: var(--bg-soft);
  }

  .wp-row,
  .wp-column,
  .wp-column-text,
  .shortcode-panel,
  .legacy-content {
    display: flow-root;
  }

  .toggle,
  .tab-section {
    margin: 18px 0;
    padding: 14px;
    border: 1px solid var(--line);
  }
</style>
